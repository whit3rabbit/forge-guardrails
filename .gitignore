# --- Rust / Cargo ---
# Compiled files and executables
target/

# Python pycache files
tests/__pycache__
*.pyc

# Cargo.lock is kept out of .gitignore by default for libraries/workspaces,
# but can be uncommented here if you wish to ignore it.
# Cargo.lock

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc
*.pdb

# --- macOS (OS X) ---
# General OS X files
.DS_Store
.AppleDouble
.LSOverride

# Icon file (often has carriage returns)
Icon?

# Thumbnails
._*

# Files that might be created on a file system of a Mac visitor
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.apdisk

# Local files
repomix-output.xml
.venv/
venv/
.syntext/
.synrepo/

# AI agent / IDE configs (local only)
.agents/
.claude/
.codex/

# LLM Models
*.gguf
.forge/classifiers/
.gitagent/

# Local verifier training-data generation artifacts
notebook/generatetd/.cache/
notebook/generatetd/.pytest_cache/
notebook/generatetd/.env
notebook/generatetd/*.egg-info/
notebook/generatetd/out/
notebook/generatetd/local_review*.jsonl