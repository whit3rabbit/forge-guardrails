      "input": "{\n  \"a\": 1,\n  \"b\": 2\n}",
      "expected_output": "{\"a\":1,\"b\":2}",
      "expected_strategies": ["json_minify"]
    },
    {
      "name": "aggressive_normalizes_dynamic_log_noise",
      "mode": "aggressive",
      "tool": "bash",
      "input": "2026-05-28T12:34:56Z completed artifact 0123456789abcdef0123456789abcdef\n",
      "expected_output": "[timestamp] completed artifact [hash]\n",
      "expected_strategies": ["normalize_dynamic_log_noise"]
    }
