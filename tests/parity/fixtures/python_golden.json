{
  "metadata": {
    "source": "forge Python reference submodule",
    "generator": "tests/parity/generate_fixtures.py",
    "command": "uv run --project forge python tests/parity/generate_fixtures.py"
  },
  "cases": {
    "anthropic_conversion_unpaired": {
      "input": [
        {
          "role": "system",
          "content": "Sys"
        },
        {
          "role": "user",
          "content": "First"
        },
        {
          "role": "assistant",
          "content": "",
          "tool_calls": [
            {
              "id": "abc",
              "function": {
                "name": "run",
                "arguments": "{}"
              }
            }
          ]
        },
        {
          "role": "user",
          "content": "next"
        }
      ],
      "expected": {
        "system": "Sys",
        "messages": [
          {
            "role": "user",
            "content": "First"
          },
          {
            "role": "assistant",
            "content": [
              {
                "type": "tool_use",
                "id": "abc",
                "name": "run",
                "input": {}
              }
            ]
          },
          {
            "role": "user",
            "content": [
              {
                "type": "tool_result",
                "tool_use_id": "abc",
                "content": "Not executed.",
                "is_error": true
              },
              {
                "type": "text",
                "text": "next"
              }
            ]
          }
        ]
      }
    },
    "anthropic_conversion_fallback_id": {
      "input": [
        {
          "role": "assistant",
          "content": "",
          "tool_calls": [
            {
              "function": {
                "name": "run",
                "arguments": "{}"
              }
            }
          ]
        },
        {
          "role": "user",
          "content": "next"
        }
      ],
      "expected": {
        "messages": [
          {
            "role": "assistant",
            "content": [
              {
                "type": "tool_use",
                "id": "toolu_0",
                "name": "run",
                "input": {}
              }
            ]
          },
          {
            "role": "user",
            "content": [
              {
                "type": "tool_result",
                "tool_use_id": "toolu_0",
                "content": "Not executed.",
                "is_error": true
              },
              {
                "type": "text",
                "text": "next"
              }
            ]
          }
        ]
      }
    },
    "inference_retry_budget": {
      "input": {
        "max_retries": 2,
        "max_attempts": 10
      },
      "expected": {
        "error_type": "ToolCallError",
        "attempts": 3,
        "raw_response": "bad 3",
        "messages": [
          {
            "role": "user",
            "content": "start",
            "type": "user_input"
          },
          {
            "role": "assistant",
            "content": "bad 1",
            "type": "text_response",
            "step_index": 0
          },
          {
            "role": "user",
            "content": "Your previous response was not a valid tool call. You must respond with a tool call, not free text. Please try again with a valid tool call.",
            "type": "retry_nudge",
            "step_index": 0
          },
          {
            "role": "assistant",
            "content": "bad 2",
            "type": "text_response",
            "step_index": 0
          },
          {
            "role": "user",
            "content": "Your previous response was not a valid tool call. You must respond with a tool call, not free text. Please try again with a valid tool call.",
            "type": "retry_nudge",
            "step_index": 0
          }
        ]
      }
    },
    "backend_error_propagation": {
      "input": {
        "status_code": 503,
        "body": "backend down"
      },
      "expected": {
        "error_type": "BackendError",
        "attempts": 1,
        "message": "Backend returned 503: backend down"
      }
    },
    "streaming_without_final": {
      "input": {
        "chunks": [
          "partial"
        ]
      },
      "expected": {
        "error_type": "StreamError",
        "attempts": 1,
        "message": "Stream ended without FINAL chunk \u2014 the client adapter may be malformed or the connection was interrupted"
      }
    },
    "llamafile_reasoning_extraction": {
      "input": {
        "content": "<think>reason</think>{\"tool\":\"run\",\"args\":{}}",
        "tools": [
          "run"
        ]
      },
      "expected": {
        "cleaned": "{\"tool\":\"run\",\"args\":{}}",
        "tool_calls": [
          {
            "tool": "run",
            "args": {},
            "reasoning": "reason"
          }
        ]
      }
    },
    "llamafile_malformed_args": {
      "input": {
        "choices": [
          {
            "message": {
              "content": "",
              "tool_calls": [
                {
                  "function": {
                    "name": "run",
                    "arguments": "{broken"
                  }
                }
              ]
            }
          }
        ]
      },
      "expected": {
        "content": ""
      }
    },
    "ollama_thinking": {
      "input": {
        "message": {
